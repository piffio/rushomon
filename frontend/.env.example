# API base URL for the Rushomon backend
# Local development
PUBLIC_VITE_API_BASE_URL=http://localhost:8787
PUBLIC_VITE_SHORT_LINK_BASE_URL=http://localhost:8787

# Production
# PUBLIC_VITE_API_BASE_URL=https://your-domain.com
# PUBLIC_VITE_SHORT_LINK_BASE_URL=https://your-redirect-domain.com

# Ephemeral environment (set by CI)
# PUBLIC_VITE_API_BASE_URL=https://rushomon-pr-123.workers.dev
# PUBLIC_VITE_SHORT_LINK_BASE_URL=https://rushomon-pr-123.workers.dev

# Polar billing configuration (for local development)
# These should match your .dev.vars values
POLAR_ACCESS_TOKEN=
POLAR_WEBHOOK_SECRET=
POLAR_SANDBOX=true
INTERNAL_WEBHOOK_SECRET=
