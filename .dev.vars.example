# Development Environment Variables Template
# ==========================================
#
# This file serves as a template for local development configuration.
#
# IMPORTANT SECURITY WARNINGS:
# - NEVER commit your actual .dev.vars file to version control
# - .dev.vars is in .gitignore for security reasons
# - These are DEVELOPMENT credentials only - use different values for production
# - Production secrets should be set via: wrangler secret put SECRET_NAME
#
# Setup Instructions:
# 1. Copy this file to .dev.vars: cp .dev.vars.example .dev.vars
# 2. Replace all placeholder values with your actual development credentials
# 3. Never share your .dev.vars file or commit it to git
#

# ─── OAuth Providers ─────────────────────────────────────────────────────────
# Only providers with a CLIENT_ID set will appear on the login page.
# You can enable one or both providers.

# GitHub OAuth Configuration
# Create a GitHub OAuth app at: https://github.com/settings/developers
# Callback URL: http://localhost:8787/api/auth/callback
GITHUB_CLIENT_ID=your-dev-github-client-id-here
GITHUB_CLIENT_SECRET=your-dev-github-client-secret-here

# Google OAuth Configuration (optional)
# Create a Google OAuth client at: https://console.cloud.google.com/apis/credentials
# Application type: Web application
# Authorised redirect URI: http://localhost:8787/api/auth/callback
# Required scopes: openid email profile
GOOGLE_CLIENT_ID=your-dev-google-client-id-here
GOOGLE_CLIENT_SECRET=your-dev-google-client-secret-here

# JWT Secret for Token Signing
# Generate a secure random string (minimum 32 characters):
#   openssl rand -base64 32
# OR:
#   node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
JWT_SECRET=your-dev-jwt-secret-minimum-32-characters-here

# ─── Email (Mailgun) ──────────────────────────────────────────────────────────
# Required for sending organization member invitations.
# Sign up at: https://www.mailgun.com/
# MAILGUN_API_KEY: Your Mailgun private API key (starts with "key-")
# MAILGUN_DOMAIN: The sending domain you configured in Mailgun (e.g. mg.yourdomain.com)
# MAILGUN_FROM: The "From" address for invitation emails
# MAILGUN_BASE_URL: The base URL for Mailgun API (e.g. https://api.mailgun.net)
MAILGUN_API_KEY=your-mailgun-api-key-here
MAILGUN_DOMAIN=mg.yourdomain.com
MAILGUN_FROM=invites@mg.yourdomain.com
MAILGUN_BASE_URL=https://api.mailgun.net

# ─── Polar (optional, required for paid plans) ───────────────────────────────
# Create an account at: https://polar.sh
# Use the sandbox environment for local development:
#   https://sandbox.polar.sh
#
# POLAR_ACCESS_TOKEN: Generate at Polar Dashboard → Settings → API
# POLAR_WEBHOOK_SECRET: Set when creating a webhook in Polar Dashboard → Settings → Webhooks
# POLAR_SANDBOX: Set to "true" for sandbox/staging, "false" for production
# POLAR_ORG_SLUG: Your Polar organization slug (for admin deep links)
# POLAR_FOUNDER_PRO_DISCOUNT_ID: Discount ID for Pro founder pricing (44% off, forever)
# POLAR_FOUNDER_BUSINESS_DISCOUNT_ID: Discount ID for Business founder pricing (34% off, forever)
# POLAR_PRO_MONTHLY_PRODUCT_ID = "your-polar-pro-monthly-product-id"
# POLAR_PRO_ANNUAL_PRODUCT_ID  = "your-polar-pro-annual-product-id"
# POLAR_BUSINESS_MONTHLY_PRODUCT_ID = "your-polar-business-monthly-product-id"
# POLAR_BUSINESS_ANNUAL_PRODUCT_ID = "your-polar-business-annual-product-id"
# INTERNAL_WEBHOOK_SECRET: A shared secret between SvelteKit frontend and this Worker
#   Generate with: openssl rand -base64 32
#
# Leave all POLAR_* vars empty/unset to disable billing (self-hosted mode).
# NOTE: POLAR_ACCESS_TOKEN and POLAR_WEBHOOK_SECRET are worker secrets (not vars)
# NOTE: INTERNAL_WEBHOOK_SECRET is a worker secret set via: wrangler secret put INTERNAL_WEBHOOK_SECRET